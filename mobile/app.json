{
  "expo": {
    "name": "InteractieveRobotArm",
    "slug": "InteractieveRobotArm",
    "version": "1.0.0",
    "orientation": "landscape",
    "icon": "./assets/robot_icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/robot_icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.osmanaktrk.InteractieveRobotArm",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": ["INTERNET", "ACCESS_NETWORK_STATE"]
    },
    "androidNavigationBar": {
      "visible": "sticky-immersive",
      "barStyle": "light-content"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "web": {
      "favicon": "./assets/robot_icon.png"
    },
    "extra": {
      "eas": {
        "projectId": "36af244a-e1ef-4393-8cc9-e8ab2260f078"
      }
    }
  }
}